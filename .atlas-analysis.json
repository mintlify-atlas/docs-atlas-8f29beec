  "keyFeatures": [
    "JWT-based authentication with role-based access control",
    "Complete ticket lifecycle management (open, in_progress, resolved, closed)",
    "Multi-user type support (admin, technician, client)",
    "Advanced ticket filtering by status, priority, technician, and client",
    "OpenAPI/Swagger documentation",
    "TypeORM integration with PostgreSQL"
  ],
  "publicApiSurface": [
    "POST /auth/login - Authenticate user and get JWT token",
    "GET /auth/profile - Get current user profile",
    "POST /tickets - Create new support ticket",
    "GET /tickets - List all tickets with optional filters",
    "GET /tickets/:id - Get ticket details by ID",
    "PATCH /tickets/:id - Update ticket status, assign technician, or change priority",
    "DELETE /tickets/:id - Delete ticket (admin only)",
    "POST /users - Register new user (admin, technician, or client)",
    "GET /users/:id - Get user details by ID"
  ]
}
